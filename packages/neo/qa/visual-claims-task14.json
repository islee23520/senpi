      "task": 14,
      "title": "diff viewer (/diff): the picker shows per-status color codes (M warning / A success / D error / ? muted) parsed from git status --porcelain, with the paging help hint",
      "requiredFrames": ["task14-diff-90"],
      "frames": [
        {
          "id": "task14-diff-90",
          "size": "90x24",
          "state": "diff-picker",
          "ans": "triplets/task14-diff-90.ans",
          "html": "triplets/task14-diff-90.html",
          "json": "triplets/task14-diff-90.json"
        }
      ],
      "assertions": [
        { "id": "diff-title-glyph", "frame": "task14-diff-90", "kind": "cell-glyph", "x": 1, "y": 0, "glyph": "S" },
        { "id": "diff-M-glyph", "frame": "task14-diff-90", "kind": "cell-glyph", "x": 2, "y": 1, "glyph": "M" },
        { "id": "diff-M-warning", "frame": "task14-diff-90", "kind": "cell-fg", "x": 2, "y": 1, "hex": "#e0af68" },
        { "id": "diff-A-success", "frame": "task14-diff-90", "kind": "cell-fg", "x": 2, "y": 2, "hex": "#9ece6a" },
        { "id": "diff-D-error", "frame": "task14-diff-90", "kind": "cell-fg", "x": 2, "y": 3, "hex": "#f7768e" },
        { "id": "diff-Q-muted", "frame": "task14-diff-90", "kind": "cell-fg", "x": 2, "y": 4, "hex": "#6c6c6c" }
      ]
    },
    {
      "id": "task-14-custom-unsupported-notice",
      "task": 14,
      "title": "third-party ctx.ui.custom notice dialog: 'this extension UI requires the classic TUI: <name>' with a warning-hue title and the extension name in accent blue",
      "requiredFrames": ["task14-notice-90"],
      "frames": [
        {
          "id": "task14-notice-90",
          "size": "90x24",
          "state": "custom-unsupported-notice",
          "ans": "triplets/task14-notice-90.ans",
          "html": "triplets/task14-notice-90.html",
          "json": "triplets/task14-notice-90.json"
        }
      ],
      "assertions": [
        { "id": "notice-title-glyph", "frame": "task14-notice-90", "kind": "cell-glyph", "x": 1, "y": 0, "glyph": "E" },
        { "id": "notice-title-warning", "frame": "task14-notice-90", "kind": "cell-fg", "x": 1, "y": 0, "hex": "#e0af68" },
        { "id": "notice-body-glyph", "frame": "task14-notice-90", "kind": "cell-glyph", "x": 1, "y": 1, "glyph": "t" },
        { "id": "notice-extname-glyph", "frame": "task14-notice-90", "kind": "cell-glyph", "x": 45, "y": 1, "glyph": "a" },
        { "id": "notice-extname-accent", "frame": "task14-notice-90", "kind": "cell-fg", "x": 45, "y": 1, "hex": "#7aa2f7" },
        { "id": "notice-bottom-rule", "frame": "task14-notice-90", "kind": "cell-glyph", "x": 0, "y": 3, "glyph": "─" }
      ]
    }
  ]
}
