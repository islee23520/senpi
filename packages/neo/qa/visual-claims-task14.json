      "assertions": [
        { "id": "files-title-glyph", "frame": "task14-files-90", "kind": "cell-glyph", "x": 1, "y": 0, "glyph": "S" },
        { "id": "files-title-accent", "frame": "task14-files-90", "kind": "cell-fg", "x": 1, "y": 0, "hex": "#7aa2f7" },
        { "id": "files-R-glyph", "frame": "task14-files-90", "kind": "cell-glyph", "x": 2, "y": 1, "glyph": "R" },
        { "id": "files-R-muted", "frame": "task14-files-90", "kind": "cell-fg", "x": 2, "y": 1, "hex": "#6c6c6c" },
        { "id": "files-E-warning", "frame": "task14-files-90", "kind": "cell-fg", "x": 3, "y": 1, "hex": "#e0af68" },
        { "id": "files-W-glyph", "frame": "task14-files-90", "kind": "cell-glyph", "x": 2, "y": 2, "glyph": "W" },
        { "id": "files-W-success", "frame": "task14-files-90", "kind": "cell-fg", "x": 2, "y": 2, "hex": "#9ece6a" }
      ]
    },
    {
