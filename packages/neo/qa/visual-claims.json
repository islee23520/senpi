{
  "$schema": "./visual-claims.schema.md",
  "description": "Visual-claims manifest for the neo grok TUI. Each claim registers the frames (size x state) that must exist as complete triplets (.ans + .html + cell-grid .json) and the grid-based assertions that must PASS. `verify-manifest` (qa/xterm-render.mjs) FAILS when any registered claim is missing a frame, missing a triplet leg, or has no PASSING grid-based assertion. Triplet paths are relative to this manifest's directory (packages/neo/qa). Task 2 registers its own theme claims below; later tasks (9-14, 20, 21, F3) append their claims here.",
  "claims": [
    {
      "id": "task-2-theme-surfaces-truecolor",
      "task": 2,
      "title": "grok-night surfaces + text tiers render at exact capture hexes (truecolor)",
      "requiredFrames": ["theme-sample-truecolor-120x8"],
      "frames": [
        {
          "id": "theme-sample-truecolor-120x8",
          "size": "120x8",
          "state": "theme-sample-truecolor",
          "ans": "triplets/theme-sample-truecolor-120x8.ans",
          "html": "triplets/theme-sample-truecolor-120x8.html",
          "json": "triplets/theme-sample-truecolor-120x8.json"
        }
      ],
      "assertions": [
        {
          "id": "base-surface-bg",
          "frame": "theme-sample-truecolor-120x8",
          "kind": "cell-bg",
          "x": 2,
          "y": 0,
          "hex": "#141414"
        },
        {
          "id": "primary-text-fg",
          "frame": "theme-sample-truecolor-120x8",
          "kind": "cell-fg",
          "x": 2,
          "y": 0,
          "hex": "#e1e1e1"
        },
        {
          "id": "primary-text-glyph",
          "frame": "theme-sample-truecolor-120x8",
          "kind": "cell-glyph",
          "x": 2,
          "y": 0,
          "glyph": "m"
        }
      ]
    },
    {
      "id": "task-2-theme-accents-and-glyphs-truecolor",
      "task": 2,
      "title": "grok tool-row glyphs (┃ ◆), spinner (⠹) and accents render at exact capture hexes",
