          "y": 1,
          "hex": "#9ece6a"
        },
        {
          "id": "tool-guide-glyph",
          "frame": "theme-sample-truecolor-120x8",
          "kind": "cell-glyph",
          "x": 30,
          "y": 2,
          "glyph": "┃"
        },
        {
          "id": "tool-guide-green",
          "frame": "theme-sample-truecolor-120x8",
          "kind": "cell-fg",
          "x": 30,
          "y": 2,
          "hex": "#9ece6a"
        },
        {
          "id": "spinner-braille-glyph",
