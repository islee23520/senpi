          "state": "theme-sample-truecolor",
          "ans": "triplets/theme-sample-truecolor-120x8.ans",
          "html": "triplets/theme-sample-truecolor-120x8.html",
          "json": "triplets/theme-sample-truecolor-120x8.json"
        }
      ],
      "assertions": [
        {
          "id": "event-marker-glyph",
          "frame": "theme-sample-truecolor-120x8",
          "kind": "cell-glyph",
          "x": 15,
          "y": 1,
          "glyph": "◆"
        },
        {
          "id": "event-marker-green",
          "frame": "theme-sample-truecolor-120x8",
