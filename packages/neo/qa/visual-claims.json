    {
      "id": "task-2-theme-256-fallback-no-truecolor",
      "task": 2,
      "title": "256-color fallback: the same panel renders with no truecolor cells (TERM=xterm) and does not crash",
      "requiredFrames": ["theme-sample-ansi256-80x8"],
      "frames": [
        {
          "id": "theme-sample-ansi256-80x8",
          "size": "80x8",
          "state": "theme-sample-ansi256",
