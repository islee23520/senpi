{
  "$schema": "https://senpi.dev/neo-tui-keymap.json",
  "version": 1,
  "leader": "ctrl+x",
  "leaderTimeoutMs": 800,
  "bindings": {
    "app.quit": ["ctrl+c ctrl+c", "<leader> q"],
    "app.cancel": ["escape"],
    "app.help": ["?", "<leader> ?"],
    "app.toggle_animations": ["<leader> a"],
    "app.toggle_sidebar": ["<leader> b"],
    "app.toggle_conceal": ["<leader> h"],
    "app.toggle_mouse_passthrough": ["<leader> m"],
    "app.cycle_focus": ["tab"],
    "app.cycle_focus_back": ["shift+tab"],
    "palette.open": ["ctrl+p"],
    "model.picker": ["ctrl+l"],
    "model.cycle": ["f2"],
    "model.cycle_back": ["shift+f2"],
    "theme.picker": ["<leader> t"],
    "session.new": ["<leader> n"],
    "session.picker": ["<leader> s"],
    "session.rename": ["ctrl+r"],
    "session.compact": ["<leader> c"],
    "thinking.cycle": ["shift+tab"],
    "chat.scroll_up": ["pageup", "ctrl+alt+b"],
    "chat.scroll_down": ["pagedown", "ctrl+alt+f"],
    "chat.line_up": ["ctrl+alt+y"],
    "chat.line_down": ["ctrl+alt+e"],
    "chat.half_page_up": ["ctrl+alt+u"],
    "chat.half_page_down": ["ctrl+alt+d"],
    "chat.first": ["home", "ctrl+g"],
    "chat.last": ["end", "ctrl+alt+g"],
    "chat.copy_message": ["<leader> y"],
    "chat.toggle_expand_tool": ["enter"],
    "input.submit": ["return"],
    "input.newline": ["shift+return", "alt+return", "ctrl+j"],
    "input.clear": ["ctrl+c"],
    "input.word_forward": ["alt+f", "alt+right", "ctrl+right"],
    "input.word_back": ["alt+b", "alt+left", "ctrl+left"],
    "input.delete_word_back": ["ctrl+w", "alt+backspace"],
    "input.delete_word_forward": ["alt+d", "alt+delete"],
    "input.history_prev": ["alt+up"],
    "input.history_next": ["alt+down"],
    "input.file_popup": ["@"],
    "input.slash_popup": ["/"],
    "input.undo": ["ctrl+z"],
    "input.redo": ["ctrl+y", "ctrl+shift+z"],
    "input.select_all": ["ctrl+a"],
    "dialog.up": ["up", "ctrl+p"],
    "dialog.down": ["down", "ctrl+n"],
    "dialog.submit": ["return"],
    "dialog.close": ["escape"],
    "dialog.page_up": ["pageup"],
    "dialog.page_down": ["pagedown"],
    "dialog.first": ["home"],
    "dialog.last": ["end"]
  }
}
