{
  "$schema": "https://senpi.dev/neo-tui-theme.json",
  "name": "senpi-neo-dark",
  "mood": "Tactile Monolith - warm studio control room",
  "type": "dark",
  "defs": {
    "espresso": "#1A1B26",
    "cardCharcoal": "#24283B",
    "elementCharcoal": "#292E42",
    "menuCharcoal": "#1F2335",
    "borderSlate": "#3B4261",
    "textSilver": "#C0CAF5",
    "textGraphite": "#565F89",
    "amberLed": "#FF9E64",
    "cyanLed": "#7DCFFF",
    "red": "#F7768E",
    "yellow": "#E0AF68",
    "green": "#9ECE6A",
    "blue": "#7AA2F7",
    "magenta": "#BB9AF7",
    "teal": "#2AC3DE",
    "mint": "#89DDFF",
    "muted": "#9AA5CE",
    "diffAddBg": "#283B4D",
    "diffRemBg": "#3F2D3D"
  },
  "tokens": {
    "primary": "amberLed",
    "secondary": "cyanLed",
    "accent": "amberLed",
    "error": "red",
    "warning": "yellow",
    "success": "green",
    "info": "blue",
    "text": "textSilver",
    "textMuted": "textGraphite",
    "textInverse": "espresso",
    "background": "espresso",
    "backgroundPanel": "cardCharcoal",
    "backgroundElement": "elementCharcoal",
    "backgroundMenu": "menuCharcoal",
    "border": "borderSlate",
    "borderActive": "amberLed",
    "borderSubtle": "elementCharcoal",
    "borderError": "red",
    "borderSuccess": "green",
    "borderInfo": "blue",
    "selectionBg": "elementCharcoal",
    "selectionFg": "textSilver",
    "cursor": "amberLed",
    "scrollbar": "borderSlate",
    "scrollbarThumb": "amberLed",
    "diffAdded": "green",
    "diffAddedBg": "diffAddBg",
    "diffRemoved": "red",
    "diffRemovedBg": "diffRemBg",
    "diffLineNumber": "textGraphite",
    "diffContext": "textGraphite",
    "markdownHeading": "cyanLed",
    "markdownCode": "muted",
    "markdownLink": "blue",
    "markdownQuote": "textGraphite",
    "markdownList": "amberLed",
    "markdownEmphasis": "textSilver",
    "markdownStrong": "amberLed",
    "markdownRule": "borderSlate",
    "syntaxComment": "textGraphite",
    "syntaxKeyword": "magenta",
    "syntaxFunction": "blue",
    "syntaxVariable": "textSilver",
    "syntaxString": "green",
    "syntaxNumber": "amberLed",
    "syntaxType": "teal",
    "syntaxOperator": "mint",
    "spinnerActive": "amberLed",
    "spinnerScannerLeading": "amberLed",
    "spinnerScannerTrail": "cardCharcoal",
    "statusIdle": "textGraphite",
    "statusBusy": "amberLed",
    "statusError": "red",
    "statusSuccess": "green",
    "toolBorderRunning": "blue",
    "toolBorderSuccess": "borderSlate",
    "toolBorderError": "red",
    "toolHeaderText": "textSilver",
    "toolBodyText": "muted",
    "userMessageBar": "amberLed",
    "assistantMessageBar": "cyanLed",
    "systemMessageBar": "textGraphite",
    "errorMessageBar": "red"
  },
  "options": {
    "thinkingOpacityPercent": 60,
    "useNerdFonts": false,
    "supportsTrueColor": true
  }
}
